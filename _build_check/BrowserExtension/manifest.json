{
  "manifest_version": 3,
  "name": "Travel Pathways Activity",
  "version": "1.0.0",
  "description": "Reports browser activity to Travel Pathways for employer monitoring (requires login).",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://localhost:44396/*",
    "https://127.0.0.1:44396/*",
    "http://localhost:5258/*",
    "http://localhost:57909/*",
    "http://127.0.0.1:5258/*",
    "http://127.0.0.1:57909/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Travel Pathways Activity"
  }
}
